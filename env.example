# =============================================================================
# kuhaku-agent-cli — environment variables
# -----------------------------------------------------------------------------
# 1. Copy this file to `.env`:           cp env.example .env
# 2. Fill in the values below.
# 3. Verify with:                        uv run kuhaku-agent doctor
# 4. Start the bot:                      uv run kuhaku-agent serve
# =============================================================================


# ── Anthropic ────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace-me

# Agent + environment IDs from the Console (or `client.beta.agents.create()`).
KUHAKU_AGENT_ID=agent_replace_me
KUHAKU_ENVIRONMENT_ID=env_replace_me

# Comma-separated vault IDs whose credentials Anthropic should make available
# to each session. Leave empty if your agent doesn't use MCP. Vaults must be
# created in the Console — this CLI never creates them.
KUHAKU_VAULT_IDS=


# ── Slack ────────────────────────────────────────────────────────────────────
# api.slack.com/apps → your app → "OAuth & Permissions" → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-replace-me

# api.slack.com/apps → your app → "Basic Information" → App-Level Tokens
# scope: connections:write
SLACK_APP_TOKEN=xapp-replace-me
